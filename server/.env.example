# Copy to .env and fill in real values.

# PostgreSQL connection string
DATABASE_URL=postgresql://localhost:5432/swapcrate

# Secret used to sign JWTs — change this to a long random string
JWT_SECRET_KEY=change-me-to-a-long-random-secret

# Frontend origin allowed to call the API (CORS). Change for production.
FRONTEND_ORIGIN=http://localhost:5173

# Set to "true" in production (HTTPS) so the auth cookie is marked Secure.
# Leave false for local http development.
COOKIE_SECURE=false

# PubNub keys (from https://admin.pubnub.com) — used for post-match messaging
PUBNUB_PUBLISH_KEY=
PUBNUB_SUBSCRIBE_KEY=
PUBNUB_SECRET_KEY=
